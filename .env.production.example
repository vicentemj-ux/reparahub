# ReparaHub production env for Coolify.
# Fill these values in Coolify, not in git.

NODE_ENV=production
PORT=3000

DATABASE_URL=
DIRECT_URL=

AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://reparahub.com
NEXT_PUBLIC_APP_URL=https://reparahub.com

AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@reparahub.com
RESEND_REPORTS_EMAIL=reportes@reparahub.com

S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=reparahub-app
S3_PUBLIC_BASE_URL=https://media.reparahub.com/reparahub-app

CRON_SECRET=
ADMIN_EMAIL=

# Legacy fallbacks. Keep during rollback window only.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=

# Legacy Supabase fallbacks. Do not use in new code.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
NEXT_PUBLIC_SUPABASE_INVENTORY_BUCKET=

# Optional CSP escape hatch for third-party renderers if a production issue appears.
CSP_ALLOW_UNSAFE_EVAL=false
