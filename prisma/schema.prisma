generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlanType {
  NORMAL
  PRO
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
}

/**
 * Rol de equipo para gestión de miembros (Mi Equipo).
 * Reemplaza el catálogo global roles_taller de Supabase.
 */
enum TeamRole {
  ADMINISTRADOR
  TECNICO
  RECEPCIONISTA
  REPARADOR
}

enum ArchivoTipo {
  REPAIR_PHOTO
  REPAIR_INTAKE_PHOTO
  REPAIR_EVIDENCE_PHOTO
  PRODUCT_PHOTO
  BUDGET_ATTACHMENT
  SIGNATURE
  HIKVISION_SNAPSHOT
  VISIT_PHOTO
  OTHER
}

enum ArchivoVisibility {
  PUBLIC_TRACK
  PRIVATE
  TRACKING_VERIFIED
  PUBLIC
  PRO_PRIVATE
}

model Tenant {
  id            String    @id @default(cuid())
  nombre        String
  slug          String    @unique
  plan          PlanType  @default(NORMAL)
  trialEndsAt   DateTime?
  timezone      String    @default("America/Mexico_City")
  currency      String    @default("MXN")
  logoUrl       String?
  paperSize     String?   @default("80mm")
  printSettings Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  users                      User[]
  clientes                   Cliente[]
  reparaciones               Reparacion[]
  archivos                   Archivo[]
  configuracion              ConfiguracionTaller?
  productos                  Producto[]
  inventarioCategorias       InventarioCategoria[]
  inventarioCategoriaAliases InventarioCategoriaAlias[]
  historialReparaciones      HistorialReparacion[]
  catalogoServicios          CatalogoServicio[]
  serviciosReparacion        ReparacionServicio[]
  ventas                     Venta[]
  apartados                  Apartado[]
  apartadoAbonos             ApartadoAbono[]
  cajas                      Caja[]
  movimientosCaja            MovimientoCaja[]
  gastosOperativos           GastoOperativo[]
  gastosReparacion           GastoReparacion[]
  colaboradoresOperativos    ColaboradorOperativo[]
  liquidacionesTrabajo        LiquidacionTrabajo[]
  liquidacionTrabajoItems     LiquidacionTrabajoItem[]
  reparacionRefacciones      ReparacionRefaccion[]
  inventarioMovimientos      InventarioMovimiento[]
  visitas                    Visita[]
  workshopMessages           WorkshopMessage[]
  proveedores                Proveedor[]
  ordenesCompra              OrdenCompra[]
  comprasUsadas              CompraUsada[]
  cotizaciones               Cotizacion[]
  cotizacionItems            CotizacionItem[]
  ajustesTaller              AjustesTaller?
  firmaDigitalTokens         FirmaDigitalToken[]
  verificationPins           VerificationPin[]
  stagingImportReparaciones  StagingImportReparacion[]
  tiendaEventos              TiendaEvento[]
  trackingAttempts           TrackingVerificationAttempt[]

  tiendaPublicaActiva Boolean   @default(false) @map("tienda_publica_activa")
  tiendaSlogan        String?   @map("tienda_slogan")
  tiendaRedes         Json?     @map("tienda_redes")
  tiendaHorarios      String?   @map("tienda_horarios")
  tiendaActivadaEn    DateTime? @map("tienda_activada_en")
}

model User {
  id                    String    @id @default(cuid())
  tenantId              String
  email                 String    @unique
  nombre                String
  passwordHash          String?
  emailVerified         Boolean   @default(true)
  sessionVersion        Int       @default(1)
  verificationToken     String?   @map("verification_token")
  verificationExpiresAt DateTime? @map("verification_expires_at")
  resetToken            String?   @map("reset_token")
  resetExpiresAt        DateTime? @map("reset_expires_at")
  role                  UserRole  @default(STAFF)
  /**
   * Rol de equipo para gestión de miembros (Mi Equipo).
   */
  teamRole              TeamRole?
  telefono              String?
  telefonoPais          String?   @map("telefono_pais")
  activo                Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accounts         Account[]
  sessions         Session[]
  verificationPins VerificationPin[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  tenantId          String?
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([tenantId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  tenantId     String?
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Cliente {
  id                 String   @id @default(cuid())
  tenantId           String
  nombre             String
  telefono           String?
  telefonoSecundario String?
  email              String?
  notas              String?
  rfc                String?
  razonSocial        String?
  codigoPostalFiscal String?
  regimenFiscal      String?
  usoCfdi            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reparaciones Reparacion[]
  ventas       Venta[]
  apartados    Apartado[]
  visitas      Visita[]

  @@index([tenantId])
  @@index([tenantId, telefono])
}

model Reparacion {
  id               String   @id @default(cuid())
  tenantId         String
  clienteId        String
  folio            String
  estado           String   @default("RECIBIDO") @map("estatus")
  tipoEquipo       String?
  equipoMarca      String?
  equipoModelo     String?
  numeroSerie      String?
  color            String?
  falla            String?
  tecnico          String?
  costoEstimado    Decimal? @map("precio_estimado") @db.Decimal(10, 2)
  anticipo         Decimal? @db.Decimal(10, 2)
  securityType     String?
  securityValue    String?
  pinContrasena    String?
  patronDesbloqueo String?
  notasInternas    String?
  checklistIngreso Json?
  checklistPro     Json?    @map("checklist_pro")
  creadoPorNombre  String?  @map("creado_por_nombre")
  esperaRefaccionConcepto String?  @map("espera_refaccion_concepto")
  esperaRefaccionEta      DateTime? @map("espera_refaccion_eta")
  esperaRefaccionNota     String?  @map("espera_refaccion_nota")
  fechaPromesaEntrega     DateTime @default(now()) @map("fecha_promesa_entrega") @db.Date
  costoTotal       Decimal? @map("costo_total") @db.Decimal(12, 2)
  firmaIngresoPath String?  @map("firma_ingreso_path")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cliente             Cliente               @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  archivos            Archivo[]
  historial           HistorialReparacion[]
  gastosReparacion    GastoReparacion[]
  liquidacionTrabajoItems LiquidacionTrabajoItem[]
  refacciones         ReparacionRefaccion[]
  serviciosReparacion ReparacionServicio[]
  firmaDigitalTokens  FirmaDigitalToken[]

  @@unique([tenantId, folio])
  @@index([tenantId])
  @@index([tenantId, estado])
  @@index([tenantId, createdAt])
  @@index([tenantId, fechaPromesaEntrega])
  @@index([clienteId])
}

/**
 * Historial unificado de actividad por reparación.
 * Reemplaza las tablas legacy historial_reparacion + cambios_reparaciones.
 */
model HistorialReparacion {
  id            String   @id @default(cuid())
  tenantId      String
  reparacionId  String
  /**
   * "estado" | "abono" | "presupuesto" | "tecnico" | "creacion" | "otro"
   */
  tipo          String
  /**
   * Descripción legible del cambio (ej: "Estado: Recibido -> Diagnostico")
   */
  descripcion   String
  valorAnterior String?
  valorNuevo    String?
  actorNombre   String?
  nota          String?
  createdAt     DateTime @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reparacion Reparacion @relation(fields: [reparacionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([reparacionId])
  @@index([tenantId, reparacionId, createdAt])
}

model Archivo {
  id           String             @id @default(cuid())
  tenantId     String
  reparacionId String?
  productoId   String?
  tipo         ArchivoTipo?
  visibility   ArchivoVisibility?
  bucket       String
  key          String
  storageKey   String?
  publicUrl    String?
  fileName     String?
  mimeType     String?
  sizeBytes    Int?
  size         Int?
  sortOrder    Int?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reparacion Reparacion? @relation(fields: [reparacionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([reparacionId])
  @@index([productoId])
}

/**
 * Log de intentos fallidos de verificacion en tracking publico.
 * Limita a 5 intentos por ticket cada 30 min para impedir fuerza bruta sobre
 * los ultimos 4 digitos del telefono del cliente.
 */
model TrackingVerificationAttempt {
  id          String   @id @default(cuid())
  tallerId    String   @map("taller_id")
  ticketId    String   @map("ticket_id")
  ip          String?  @map("ip")
  success     Boolean  @default(false) @map("success")
  attemptedAt DateTime @default(now()) @map("attempted_at")

  tenant Tenant @relation(fields: [tallerId], references: [id], onDelete: Cascade)

  @@index([ticketId, attemptedAt])
  @@index([tallerId, attemptedAt])
  @@map("tracking_verification_attempts")
}

model ConfiguracionTaller {
  id                  String    @id @default(cuid())
  tenantId            String    @unique
  nombreComercial     String?
  direccion           String?
  telefono            String?
  emailContacto       String?
  ciudad              String?
  estado              String?
  pais                String?
  moneda              String?   @default("MXN")
  timezone            String?   @default("America/Mexico_City")
  fondoCajaInicial    Decimal   @default(500) @map("fondo_caja_inicial") @db.Decimal(12, 2)
  logoUrl             String?
  logoStorageKey      String?
  whatsapp            String?
  paperSize           String?   @default("80mm")
  labelSize           String?   @default("2x1")
  printSettings       Json?
  uiPreferences       Json?     @map("ui_preferences")
  terminosGarantia    String?
  diasGarantia        Int?      @default(30)
  mensajeDespedida    String?
  /// Switch maestro de "Inventario bajo". Default `true` para que Pro/Trial
  /// arranquen con la alerta activa; el usuario puede apagarla manualmente.
  alertasStockBajo    Boolean?  @default(true)
  /// Switch maestro de "Cierre de caja". Default `true`.
  reportesCierreCaja  Boolean?  @default(true)
  /// Switch maestro de "Equipos sin movimiento". Default `true`.
  alertaUrgentes      Boolean?  @default(true)
  /// Ultima vez que `runDailyAlertsCheck` ejecuto para este tenant (en UTC).
  /// Usado para dedupe diario respetando la zona horaria del taller.
  lastDailyAlertsAt   DateTime? @map("last_daily_alerts_at")
  prefijoFolio        String?   @default("REP")
  siguienteFolio      Int?      @default(1)
  facebook            String?
  instagram           String?
  tiktok              String?
  /// Persona responsable del local (dueno, gerente, encargado, socio, etc.).
  /// Dato PRIVADO: NO se imprime en tickets ni en el reporte en carta. Solo
  /// se usa como destinatario del corte de caja (WhatsApp + correo) y de las
  /// alertas diarias. Si esta vacio, cae a `emailContacto` y luego al
  /// email del owner de la sesion (ver `lib/email/recipients.ts`).
  responsableNombre   String?   @map("responsable_nombre")
  responsableCargo    String?   @map("responsable_cargo")
  responsableTelefono String?   @map("responsable_telefono")
  responsableEmail    String?   @map("responsable_email")
  wizardCompletado    Boolean?  @default(false) @map("wizard_completado")
  camaraConfig        Json?     @map("camara_config")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  alertas AlertaEnviada[]

  @@index([tenantId])
}

model AjustesTaller {
  tenantId            String   @id @map("taller_id")
  healthCheckRequired Boolean  @default(false) @map("health_check_required")
  firmaRequired       Boolean  @default(false) @map("firma_required")
  fotosRequired       Boolean  @default(false) @map("fotos_required")
  updatedAt           DateTime @default(now()) @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("ajustes_taller")
}

/**
 * Analytics de la tienda pública de un tenant.
 * Eventos discretos: visita de catalogo, clic en producto, clic en WhatsApp.
 * No contiene PII ni cookies invasivas.
 */
model TiendaEvento {
  id         String   @id @default(cuid())
  tenantId   String   @map("taller_id")
  tipo       String
  productoId String?  @map("producto_id")
  referrer   String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, tipo])
  @@index([tenantId, productoId])
  @@map("tienda_eventos")
}

/**
 * Bitacora de alertas/reportes enviados automaticamente por el motor de
 * "Reportes y Alertas" (lib/actions/alertas-prisma.ts). Permite auditar
 * que se envio, a quien, cuantos items cubrio y reintentar en caso de
 * fallo del proveedor de correo.
 */
model AlertaEnviada {
  id               String   @id @default(cuid())
  configId         String   @map("config_id")
  tipo             String
  /// Email destino (resuelto de `emailContacto` o fallback al owner).
  destinatario     String
  /// Resumen serializado (JSON) con el payload del email: lista de items,
  /// totales, etc. Vacio para el reporte diario de cierre.
  resumen          String?
  /// IDs de mensaje devueltos por Resend (separados por coma si fueron varios).
  resendMessageIds String?  @map("resend_message_ids")
  /// `ok` cuando Resend respondio 2xx; `error` con el mensaje guardado.
  estado           String   @default("ok")
  detalleError     String?  @map("detalle_error")
  createdAt        DateTime @default(now()) @map("created_at")

  config ConfiguracionTaller @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId, createdAt])
  @@index([configId, tipo, createdAt])
  @@map("alertas_enviadas")
}

model Producto {
  id                 String   @id @default(cuid())
  tenantId           String   @map("taller_id")
  nombre             String
  sku                String?
  codigoBarras       String?  @map("codigo_barras")
  imagenUrl          String?  @map("imagen_url")
  categoria          String?
  descripcion        String?
  marca              String?
  modelo             String?
  ubicacion          String?
  costo              Decimal  @default(0) @db.Decimal(12, 2)
  precioVenta        Decimal  @default(0) @map("precio_venta") @db.Decimal(12, 2)
  stockActual        Int      @default(0) @map("stock_actual")
  stockMinimo        Int      @default(0) @map("stock_minimo")
  esEquipo           Boolean  @default(false) @map("es_equipo")
  imeiSerie          String?  @map("imei_serie")
  color              String?
  capacidad          String?
  procesador         String?
  ram                String?
  almacenamiento     String?
  condicion          String?
  publicadoEnTienda  Boolean  @default(false) @map("publicado_en_tienda")
  ordenTienda        Int      @default(0) @map("orden_tienda")
  descripcionPublica String?  @map("descripcion_publica")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt

  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apartados             Apartado[]
  reparacionRefacciones ReparacionRefaccion[]
  inventarioMovimientos InventarioMovimiento[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, stockActual])
  @@index([tenantId, categoria])
  @@index([tenantId, codigoBarras])
  @@index([tenantId, publicadoEnTienda])
  @@index([tenantId, publicadoEnTienda, ordenTienda])
  @@map("productos")
}

/**
 * Venta de mostrador (POS).
 * Tabla legacy creada via raw SQL, nombre lowercase.
 */
model Venta {
  id                 String   @id @default(cuid())
  tenantId           String   @map("taller_id")
  cajaId             String?  @map("caja_id")
  folio              String
  clienteNombre      String?  @map("cliente_nombre")
  clienteId          String?  @map("cliente_id")
  clienteTelefono    String?  @map("cliente_telefono")
  total              Decimal  @default(0) @db.Decimal(12, 2)
  descuento          Decimal  @default(0) @db.Decimal(12, 2)
  metodoPago         String   @default("efectivo") @map("metodo_pago")
  montoEfectivo      Decimal  @default(0) @map("monto_efectivo") @db.Decimal(12, 2)
  montoTarjeta       Decimal  @default(0) @map("monto_tarjeta") @db.Decimal(12, 2)
  montoTransferencia Decimal  @default(0) @map("monto_transferencia") @db.Decimal(12, 2)
  cambio             Decimal  @default(0) @db.Decimal(12, 2)
  referenciaPago     String?  @map("referencia_pago")
  estado             String   @default("activa")
  vendedorNombre     String?  @map("vendedor_nombre")
  createdAt          DateTime @default(now()) @map("created_at")

  tenant               Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cliente              Cliente?       @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  caja                 Caja?          @relation(fields: [cajaId], references: [id])
  detalles             DetalleVenta[]
  apartadosFinalizados Apartado[]

  @@unique([tenantId, folio])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, clienteId])
  @@index([cajaId])
  @@map("ventas")
}

/**
 * Linea individual dentro de una venta de mostrador.
 */
model DetalleVenta {
  id             String   @id @default(cuid())
  ventaId        String   @map("venta_id")
  productoId     String?  @map("producto_id")
  descripcion    String
  cantidad       Int      @default(1)
  precioUnitario Decimal  @map("precio_unitario") @db.Decimal(12, 2)
  costoUnitario  Decimal  @default(0) @map("costo_unitario") @db.Decimal(12, 2)
  subtotal       Decimal  @default(0) @db.Decimal(12, 2)
  esEspecial     Boolean  @default(false) @map("es_especial")
  referencia     String?
  imeiSerie      String?  @map("imei_serie")
  color          String?
  condicion      String?
  marca          String?
  modelo         String?
  categoria      String?
  procesador     String?
  ram            String?
  almacenamiento String?
  createdAt      DateTime @default(now()) @map("created_at")

  venta Venta @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  @@index([ventaId])
  @@map("detalle_ventas")
}

/**
 * Apartado de producto dentro del POS.
 * Reserva inventario al crear el apartado y se liquida mediante abonos.
 */
model Apartado {
  id                String    @id @default(cuid())
  tenantId          String    @map("taller_id")
  clienteId         String    @map("cliente_id")
  productoId        String    @map("producto_id")
  cajaId            String?   @map("caja_id")
  ventaFinalId      String?   @map("venta_final_id")
  folio             String
  productoNombre    String    @map("producto_nombre")
  productoSku       String?   @map("producto_sku")
  cantidad          Int       @default(1)
  precioAcordado    Decimal   @map("precio_acordado") @db.Decimal(12, 2)
  totalAbonado      Decimal   @default(0) @map("total_abonado") @db.Decimal(12, 2)
  saldo             Decimal   @default(0) @db.Decimal(12, 2)
  estado            String    @default("activo")
  fechaLimite       DateTime  @map("fecha_limite") @db.Date
  fechaLiquidacion  DateTime? @map("fecha_liquidacion")
  fechaCancelacion  DateTime? @map("fecha_cancelacion")
  motivoCancelacion String?   @map("motivo_cancelacion")
  vendedorNombre    String?   @map("vendedor_nombre")
  notas             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cliente  Cliente         @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  producto Producto        @relation(fields: [productoId], references: [id], onDelete: Restrict)
  caja     Caja?           @relation(fields: [cajaId], references: [id], onDelete: SetNull)
  venta    Venta?          @relation(fields: [ventaFinalId], references: [id], onDelete: SetNull)
  abonos   ApartadoAbono[]

  @@unique([tenantId, folio])
  @@index([tenantId])
  @@index([tenantId, estado])
  @@index([tenantId, fechaLimite])
  @@index([clienteId])
  @@index([productoId])
  @@index([cajaId])
  @@map("apartados")
}

/**
 * Abono aplicado a un apartado.
 * Cada registro tambien crea un movimiento_caja tipo apartado_abono.
 */
model ApartadoAbono {
  id             String   @id @default(cuid())
  tenantId       String   @map("taller_id")
  apartadoId     String   @map("apartado_id")
  cajaId         String?  @map("caja_id")
  monto          Decimal  @db.Decimal(12, 2)
  metodoPago     String   @map("metodo_pago")
  referenciaPago String?  @map("referencia_pago")
  vendedorNombre String?  @map("vendedor_nombre")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apartado Apartado @relation(fields: [apartadoId], references: [id], onDelete: Cascade)
  caja     Caja?    @relation(fields: [cajaId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([apartadoId])
  @@index([cajaId])
  @@map("apartado_abonos")
}

/**
 * Caja diaria (corte de caja).
 * Tabla legacy creada via raw SQL, nombre lowercase.
 */
model Caja {
  id                 String    @id @default(cuid())
  tenantId           String    @map("taller_id")
  montoInicial       Decimal   @default(0) @map("monto_inicial") @db.Decimal(12, 2)
  montoCierre        Decimal?  @map("monto_cierre") @db.Decimal(12, 2)
  fechaApertura      DateTime  @default(now()) @map("fecha_apertura")
  fechaCierre        DateTime? @map("fecha_cierre")
  estado             String    @default("abierta")
  totalEfectivo      Decimal   @default(0) @map("total_efectivo") @db.Decimal(12, 2)
  totalTarjeta       Decimal   @default(0) @map("total_tarjeta") @db.Decimal(12, 2)
  totalTransferencia Decimal   @default(0) @map("total_transferencia") @db.Decimal(12, 2)
  totalVentas        Int       @default(0) @map("total_ventas")
  notaCierre         String?   @map("nota_cierre")
  numeroCorte        Int?      @map("numero_corte")

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ventas         Venta[]
  movimientos    MovimientoCaja[]
  apartados      Apartado[]
  apartadoAbonos ApartadoAbono[]

  @@index([tenantId])
  @@index([tenantId, estado])
  @@map("caja")
}

/**
 * Movimiento de caja (ventas PDV, abonos reparaciones, gastos).
 * Tabla legacy creada via raw SQL, nombre lowercase.
 */
model MovimientoCaja {
  id             String   @id @default(cuid())
  tenantId       String   @map("taller_id")
  cajaId         String?  @map("caja_id")
  tipo           String
  referenciaId   String?  @map("referencia_id")
  descripcion    String?
  monto          Decimal  @default(0) @db.Decimal(12, 2)
  metodoPago     String?  @map("metodo_pago")
  fecha          DateTime @default(now())
  folio          String?
  vendedorNombre String?  @map("vendedor_nombre")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  caja   Caja?  @relation(fields: [cajaId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, fecha])
  @@index([cajaId])
  @@index([cajaId, tipo, metodoPago])
  @@index([tipo])
  @@map("movimientos_caja")
}

/**
 * Gasto operativo del taller (Bitácora de Gastos).
 * Tabla legacy creada via raw SQL en Supabase, ahora gestionada por Prisma.
 */
model ColaboradorOperativo {
  id            String   @id @default(cuid())
  tenantId      String   @map("taller_id")
  nombre        String
  tipo          String   @default("tecnico")
  telefono      String?
  telefonoPais  String?  @map("telefono_pais")
  tarifaDefault Decimal? @map("tarifa_default") @db.Decimal(12, 2)
  activo        Boolean  @default(true)
  notas         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  liquidaciones LiquidacionTrabajo[]

  @@unique([tenantId, nombre, tipo], map: "colab_oper_tenant_nombre_tipo_key")
  @@index([tenantId], map: "colab_oper_tenant_idx")
  @@index([tenantId, tipo, activo], map: "colab_oper_tenant_tipo_activo_idx")
  @@map("colaboradores_operativos")
}

model LiquidacionTrabajo {
  id                String   @id @default(cuid())
  tenantId          String   @map("taller_id")
  colaboradorId     String?  @map("colaborador_id")
  colaboradorNombre String   @map("colaborador_nombre")
  colaboradorKey    String   @map("colaborador_key")
  tipo              String
  metodoPago        String   @map("metodo_pago")
  periodoDesde      DateTime @map("periodo_desde")
  periodoHasta      DateTime @map("periodo_hasta")
  montoTotal        Decimal  @default(0) @map("monto_total") @db.Decimal(12, 2)
  estado            String   @default("confirmada")
  creadoPorNombre   String?  @map("creado_por_nombre")
  createdAt         DateTime @default(now()) @map("created_at")

  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  colaborador ColaboradorOperativo? @relation(fields: [colaboradorId], references: [id], onDelete: SetNull)
  items       LiquidacionTrabajoItem[]

  @@index([tenantId], map: "liq_trabajo_tenant_idx")
  @@index([tenantId, colaboradorKey, createdAt], map: "liq_trabajo_tenant_colab_created_idx")
  @@index([tenantId, periodoDesde, periodoHasta], map: "liq_trabajo_tenant_periodo_idx")
  @@map("liquidaciones_trabajo")
}

model GastoOperativo {
  id         String   @id @default(cuid())
  tenantId   String   @map("taller_id")
  concepto   String
  categoria  String   @default("general")
  monto      Decimal  @db.Decimal(10, 2)
  metodoPago String   @default("efectivo") @map("metodo_pago")
  fecha      DateTime
  notas      String?
  cajaId     String?  @map("caja_id")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, fecha])
  @@map("bitacora_gastos")
}

/**
 * Gasto asociado a un ticket de reparación (inversión).
 * Tabla legacy creada via raw SQL en Supabase, ahora gestionada por Prisma.
 */
model GastoReparacion {
  id              String   @id @default(cuid())
  tenantId        String   @map("taller_id")
  reparacionId    String   @map("reparacion_id")
  liquidacionItemId String? @unique @map("liquidacion_item_id")
  concepto        String
  monto           Decimal  @db.Decimal(10, 2)
  tipo            String
  productoId      String?  @map("producto_id")
  mostrarCliente  Boolean  @default(false) @map("mostrar_cliente")
  creadoPorNombre String?  @map("creado_por_nombre")
  createdAt       DateTime @default(now()) @map("created_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reparacion Reparacion @relation(fields: [reparacionId], references: [id], onDelete: Cascade)
  liquidacionItem LiquidacionTrabajoItem? @relation(fields: [liquidacionItemId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, reparacionId])
  @@map("reparacion_gastos")
}

model LiquidacionTrabajoItem {
  id                String   @id @default(cuid())
  tenantId          String   @map("taller_id")
  liquidacionId     String   @map("liquidacion_id")
  reparacionId      String   @map("reparacion_id")
  colaboradorKey    String   @map("colaborador_key")
  colaboradorNombre String   @map("colaborador_nombre")
  tipo              String
  dedupeKey         String   @default("principal") @map("dedupe_key")
  motivoExcepcion   String?  @map("motivo_excepcion")
  concepto          String
  monto             Decimal  @db.Decimal(12, 2)
  fechaTerminado    DateTime @map("fecha_terminado")
  estado            String   @default("confirmada")
  createdAt         DateTime @default(now()) @map("created_at")

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  liquidacion LiquidacionTrabajo @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)
  reparacion  Reparacion         @relation(fields: [reparacionId], references: [id], onDelete: Cascade)
  gasto       GastoReparacion?

  @@unique([tenantId, reparacionId, colaboradorKey, tipo, dedupeKey], map: "liq_item_dedupe_key")
  @@index([tenantId], map: "liq_item_tenant_idx")
  @@index([tenantId, liquidacionId], map: "liq_item_tenant_liq_idx")
  @@index([tenantId, colaboradorKey, tipo], map: "liq_item_tenant_colab_tipo_idx")
  @@map("liquidacion_trabajo_items")
}

/**
 * Refacciones consumidas desde inventario dentro de un folio.
 * Se separa de GastoReparacion para no mezclar costo interno, caja y stock.
 */
model ReparacionRefaccion {
  id                  String    @id @default(cuid())
  tenantId            String    @map("taller_id")
  reparacionId        String    @map("reparacion_id")
  productoId          String    @map("producto_id")
  conceptoSnapshot    String    @map("concepto_snapshot")
  skuSnapshot         String?   @map("sku_snapshot")
  cantidad            Int       @default(1)
  costoUnitario       Decimal   @map("costo_unitario") @db.Decimal(12, 2)
  precioVentaSnapshot Decimal   @default(0) @map("precio_venta_snapshot") @db.Decimal(12, 2)
  precioCliente       Decimal   @default(0) @map("precio_cliente") @db.Decimal(12, 2)
  priceMode           String    @default("included_in_service") @map("price_mode")
  estado              String    @default("consumed")
  mostrarCliente      Boolean   @default(false) @map("mostrar_cliente")
  creadoPorNombre     String?   @map("creado_por_nombre")
  motivoCancelacion   String?   @map("motivo_cancelacion")
  consumedAt          DateTime? @default(now()) @map("consumed_at")
  returnedAt          DateTime? @map("returned_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reparacion Reparacion @relation(fields: [reparacionId], references: [id], onDelete: Cascade)
  producto   Producto   @relation(fields: [productoId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, reparacionId])
  @@index([tenantId, productoId])
  @@index([tenantId, estado])
  @@map("reparacion_refacciones")
}

/**
 * Ledger auditable de entradas/salidas de inventario.
 * No reemplaza stockActual: explica por que cambio.
 */
model InventarioMovimiento {
  id             String   @id @default(cuid())
  tenantId       String   @map("taller_id")
  productoId     String   @map("producto_id")
  tipo           String
  referenciaTipo String?  @map("referencia_tipo")
  referenciaId   String?  @map("referencia_id")
  cantidad       Int
  stockAntes     Int      @map("stock_antes")
  stockDespues   Int      @map("stock_despues")
  costoUnitario  Decimal? @map("costo_unitario") @db.Decimal(12, 2)
  nota           String?
  actorNombre    String?  @map("actor_nombre")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, productoId])
  @@index([tenantId, tipo, createdAt])
  @@index([referenciaTipo, referenciaId])
  @@map("inventario_movimientos")
}

